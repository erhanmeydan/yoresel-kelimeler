{
  "name": "yoresel-kelimeler",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:web": "vite build",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "emulators": "firebase emulators:start",
    "deploy": "npm run build && firebase deploy",
    "seed": "tsx scripts/seed.ts",
    "seed:regions": "tsx scripts/seed.ts",
    "seed:entries": "tsx scripts/seed-entries.ts",
    "test:rules": "firebase emulators:exec --only firestore 'vitest run tests/rules'",
    "test:moderation:setup": "node scripts/create-test-admin.mjs",
    "test:moderation": "node scripts/test-moderation-headless.mjs"
  },
  "dependencies": {
    "firebase": "^11.0.0",
    "leaflet": "^1.9.4"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^3.0.0",
    "@types/jsdom": "^28.0.3",
    "@types/leaflet": "^1.9.12",
    "dotenv": "^16.4.0",
    "firebase-admin": "^12.0.0",
    "jsdom": "^29.1.1",
    "puppeteer": "^25.2.1",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.0"
  }
}
