{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "lib",
    "rootDirs": ["src", "../src/utils"],
    "paths": {
      "@shared/*": ["../src/utils/*"]
    }
  },
  "include": ["src", "../src/utils/searchTokens.ts"]
}