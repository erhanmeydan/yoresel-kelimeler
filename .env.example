# Firebase Web App config — Firebase Console → Project Settings → General → Your apps
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Emulator: "true" enables Auth + Firestore emulators
VITE_USE_EMULATORS=

# Service account (for admin scripts like seed/backfill). Either JSON inline
# or path to a file. NEVER commit real credentials.
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_SERVICE_ACCOUNT_PATH=./service-account.json
